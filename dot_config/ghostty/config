theme = light:Blue Dolphin,dark:Citruszest
# theme = Blue Dolphin
# theme = Citruszest

font-family = "Hack Nerd Font Mono"
font-size = 14
font-thicken = true
font-thicken-strength = 200
bold-is-bright = true

# window stuff
initial-window = false
window-theme = auto
window-inherit-working-directory = false
window-decoration = true
window-padding-x = 8
window-padding-y = 8

# zellij unbinds
keybind = cmd+t=unbind
keybind = cmd+n=unbind
keybind = cmd+c=unbind
keybind = cmd+w=unbind
keybind = cmd+opt+left=unbind
keybind = cmd+opt+right=unbind
keybind = ctrl+enter=unbind

background-opacity = 0.83
background-blur = true

# operations
quit-after-last-window-closed = false

# shell integration
shell-integration = detect
shell-integration-features = cursor, sudo, title

# quick terminal
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-size = 55%,94%
quick-terminal-animation-duration = 0.2
quick-terminal-autohide = true
quick-terminal-screen = macos-menu-bar
quick-terminal-space-behavior = move
quick-terminal-keyboard-interactivity = on-demand

# osx specific operations
macos-option-as-alt = left
macos-window-shadow = false
macos-auto-secure-input = true
macos-secure-input-indication = true

