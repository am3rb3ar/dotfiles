
{{ if .work }}
# Work-only environment variables
# set -x WORK_VAR value
{{ end -}}


set -gx EDITOR "$HOME/.local/bin/nvim-wrapper"
set -gx VISUAL "$HOME/.local/bin/nvim-wrapper"

# help with pyenv c compilations
# hardcoded to avoid 3x `brew --prefix openssl` subprocess spawns on every shell start;
# /opt/homebrew/opt/openssl is brew's version-agnostic symlink, equivalent to `brew --prefix openssl`
set -l openssl_prefix "/opt/homebrew/opt/openssl"
set -l openssl_ld_flag "-Wl,-rpath,$openssl_prefix/lib"
set -l libpq_ld_flag "-L/opt/homebrew/opt/libpq/lib"
set -l zlib_ld_flag "-L/opt/homebrew/opt/zlib/lib"
set -gx LDFLAGS "$openssl_ld_flag $libpq_ld_flag $zlib_ld_flag"

set -l openssl_cpp_flag "-Wl,-rpath,$openssl_prefix/lib"
set -l libpq_cpp_flag "-I/opt/homebrew/opt/libpq/include"
set -l zlib_cpp_flag "-I/opt/homebrew/opt/zlib/include"
set -gx CPPFLAGS "$openssl_cpp_flag $libpq_cpp_flag $zlib_cpp_flag"

set -gx CONFIGURE_OPTS "--with-openssl=$openssl_prefix"

# Go
set -gx GOENV_PATH_ORDER front

# Pyenv
set -gx PYENV_ROOT "$HOME/.pyenv"
test -d "$PYENV_ROOT/bin" && fish_add_path "$PYENV_ROOT/bin"

# Poetry
set -gx POETRY_CONFIG_DIR = "$HOME/.config/pypoetry"
set -gx POETRY_DATA_DIR = "$HOME/.local/share/pypoetry"
set -gx POETRY_CACHE_DIR = "$HOME/.cache/pypoetry"

# uv
set -gx UV_PYTHON_PREFERENCE "system"

# Ruby
set -gx OBJC_DISABLE_INITIALIZE_FORK_SAFETY YES

# Node/Volta
set -gx VOLTA_HOME "$XDG_DATA_HOME/volta"
test -d "$VOLTA_HOME/bin" && fish_add_path "$VOLTA_HOME/bin"

# kubectl
set -gx KUBECONFIG "$XDG_CONFIG_HOME/kube/config"

# AWS
set -gx AWS_CONFIG_FILE "$XDG_CONFIG_HOME/aws/config"
set -gx AWS_SHARED_CREDENTIALS_FILE "$XDG_CONFIG_HOME/aws/credentials"

# VS Code
set -l VSCODE_BIN "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
test -d "$VSCODE_BIN" && fish_add_path "$VSCODE_BINE"

# bat
set -gx BAT_CONFIG_DIR "$XDG_CONFIG_HOME/bat"
set -gx BAT_CONFIG_PATH "$BAT_CONFIG_DIR/bat.conf"
set -gx BAT_PAGER "less -RFX"

# fzf
set -gx FZF_DEFAULT_COMMAND 'fd --type f --hidden --follow --exclude .git'

# CloudSmith
set -gx CLOUDSMITH_USERNAME "daniel-blum"

# Obsidian Path
fish_add_path "/Applications/Obsidian.app/Contents/MacOS"

# starship
set -gx STARSHIP_CONFIG "$XDG_CONFIG_HOME/starship.toml"
