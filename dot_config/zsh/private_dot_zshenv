# .zshenv
#
# Remember Order of Operations
# 1. .zshenv
# 2. .zpofile for login shell
# 3. .zshrc for interactive shell
# 4. .zlogin for login POST interactive
# 5. .zlogout for login out
#
#


# Getting .config file going on
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# ZSH Config location
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

export EDITOR="$HOME/.local/bin/nvim-wrapper"
export VISUAL="$HOME/.local/bin/nvim-wrapper"

export HISTFILE="$XDG_CACHE_HOME/zhistory"
export HISTSIZE=10000
export SAVEHIST=10000

################################################################################
# NETSKOPE CERTIFICATE CONFIGURATION

export AWS_CA_BUNDLE="/Users/Shared/Netskope/nscacert_combined.pem"
export REQUESTS_CA_BUNDLE="/Users/Shared/Netskope/nscacert_combined.pem"
export SSL_CERT_FILE="/Users/Shared/Netskope/nscacert_combined.pem"
export NODE_EXTRA_CA_CERTS="/Users/Shared/Netskope/nscacert_combined.pem"
export GIT_SSL_CAINFO="/Users/Shared/Netskope/nscacert_combined.pem"

# END NETSKOPE CERTIFICATE CONFIGURATION
################################################################################

# Ensure brew is in the patch when setting up envvariables
# This also adds some homebrew specific env variables

eval "$(/opt/homebrew/bin/brew shellenv)"

openssl_ld_flag="-Wl,-rpath,$(brew --prefix openssl)/lib"
libpq_ld_flag="-L/opt/homebrew/opt/libpq/lib"
zlib_ld_flag="-L/opt/homebrew/opt/zlib/lib"
# llvm_ld_flags="-L/opt/homebrew/opt/llvm/lib"
export LDFLAGS="$openssl_ld_flag $libpq_ld_flag $zlib_ld_flag"

openssl_cpp_flag="-Wl,-rpath,$(brew --prefix openssl)/lib"
libpq_cpp_flag="-I/opt/homebrew/opt/libpq/include"
zlib_cpp_flag="-I/opt/homebrew/opt/zlib/include"
# llvm_cpp_flags="-I/opt/homebrew/opt/llvm/include"
export CPPFLAGS="$openssl_cpp_flag $libpq_cpp_flag $zlib_cpp_flag"

export CONFIGURE_OPTS="--with-opensll=$(brew --prefix openssl)"

# general location fo app support on OSX
app_support="/Users/daniel.blum/Library/Application Support"

# Rust Config ----------------------------------------------------------------
# ----------------------------------------------------------------------------
export RUSTUP_HOME="${XDG_CONFIG_HOME}/rustup"
export CARGO_HOME="${XDG_CONFIG_HOME}/cargo"
export PATH="${CARGO_HOME}/bin:$PATH"
source "${CARGO_HOME}/env"


# Java Config ----------------------------------------------------------------
# ----------------------------------------------------------------------------
export SDKMAN_DIR="${app_support}/sdkman"

# GO -------------------------------------------------------------------------
# ----------------------------------------------------------------------------
export GOPATH="$HOME/.local/share/go"
export PATH="$GOPATH/bin:$PATH"
# currently has global install at /usr/local/go/bin



# Pyenv ----------------------------------------------------------------------
# ----------------------------------------------------------------------------
# this isn't a configuration folder so DON'T put it in XDG_CONFIG_HOME
export PYENV_ROOT="$HOME/.pyenv"

# uv -------------------------------------------------------------------------
# ----------------------------------------------------------------------------
export UV_PYTHON_PREFERENCE="system"

# Ruby -----------------------------------------------------------------------
# ----------------------------------------------------------------------------
# source /Users/daniel.blum/.rvm/scripts/rvm
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES #issue with checkov

# Terraform ------------------------------------------------------------------
# ----------------------------------------------------------------------------
# You're using `tfswitch` to manage TF versions
export TF_VERSION=1.14
export TF_PRODUCT="terraform"

# Node -----------------------------------------------------------------------
# ----------------------------------------------------------------------------
# THIS IS DECLARED IN `.zshrc` AT THE END OF THE FILE.
# someting was setting a system version of node so this was never picked
# Volta (for managing tools) https://docs.volta.sh/guide/getting-started
export VOLTA_HOME="$XDG_DATA_HOME/volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# kubectl --------------------------------------------------------------------
export KUBECONFIG="${XDG_CONFIG_HOME}/kube/config"

# AWS config/credential ------------------------------------------------------
export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"

# VS Code --------------------------------------------------------------------
# ----------------------------------------------------------------------------
export PATH="/Applications/Visual Studio Code.app/Contents/Resources/app/bin:$PATH"


# bat ------------------------------------------------------------------------
# ----------------------------------------------------------------------------
export BAT_CONFIG_DIR="${XDG_CONFIG_HOME}/bat"
export BAT_CONFIG_PATH="${BAT_CONFIG_DIR}/bat.conf"
export BAT_PAGER="less -RFX"
 

# fzf ------------------------------------------------------------------------
# ----------------------------------------------------------------------------
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'


# cloudsmith -----------------------------------------------------------------
# ----------------------------------------------------------------------------
export CLOUDSMITH_USERNAME="daniel-blum"

# bottom of the page ---------------------------------------------------------
# ----------------------------------------------------------------------------
export PATH="$PATH:/Users/daniel.blum/.local/bin"
